                  "operationMetadataId": "1f530c87-ba5e-44f2-8aa2-63712215990d"
                }
              },
              "Set_Batch_from_Next_AI": {
                "type": "SetVariable",
                "inputs": {
                  "name": "varBatch",
                  "value": "@{if(less(outputs('Compose_-_Position_of_Next_AI'), 999), if(less(outputs('Compose_-_Position_of_Next_AI'), 2), outputs('Compose_-_Post-Batch_String'), substring(outputs('Compose_-_Post-Batch_String'), 0, outputs('Compose_-_Position_of_Next_AI'))), outputs('Compose_-_Post-Batch_String'))}"
                },
                "runAfter": {
                  "Compose_-_Position_of_Next_AI": [
