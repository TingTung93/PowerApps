                "inputs": "@min(if(greater(indexOf(outputs('Compose_-_Post-Batch_String'), '21'), 0), indexOf(outputs('Compose_-_Post-Batch_String'), '21'), 999), if(greater(indexOf(outputs('Compose_-_Post-Batch_String'), '240'), 0), indexOf(outputs('Compose_-_Post-Batch_String'), '240'), 999), if(greater(indexOf(outputs('Compose_-_Post-Batch_String'), '30'), 0), indexOf(outputs('Compose_-_Post-Batch_String'), '30'), 999), if(greater(indexOf(outputs('Compose_-_Post-Batch_String'), '91'), 0), indexOf(outputs('Compose_-_Post-Batch_String'), '91'), 999))",
